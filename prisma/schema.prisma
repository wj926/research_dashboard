// This is your Prisma schema file.
// Mirrors lib/types.ts with extensibility columns for future external-source sync.

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ========== Members ==========
model Member {
  login              String    @id
  displayName        String
  role               String
  avatarUrl          String?
  email              String?   @unique // OAuth email (nullable until first login)
  githubLogin        String?   @unique // GitHub handle (nullable until admin sets it)
  bio                String?
  pinnedProjectSlugs String    // JSON array stored as string
  source             String    @default("internal")
  externalId         String?   @unique
  lastSyncedAt       DateTime?

  authoredPapers      PaperAuthor[]
  memberProjects      ProjectMember[]
  triggeredRuns       ExperimentRun[]
  authoredDiscussions Discussion[]
  authoredReplies     Reply[]
  authoredEvents      ActivityEvent[]
  journalEntries      ResearchEntry[]

  // Back-relation from NextAuth User (optional one-to-one)
  user User?
}

// ========== NextAuth.js v5 tables ==========
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  accounts Account[]
  sessions Session[]

  // Link to our domain Member by login (nullable until first successful signIn)
  memberLogin String? @unique
  member      Member? @relation(fields: [memberLogin], references: [login], onDelete: SetNull)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ========== Projects ==========
model Project {
  slug           String    @id
  name           String
  description    String
  tags           String    // JSON array
  pinned         Boolean
  createdAt      DateTime
  updatedAt      DateTime
  source         String    @default("internal")
  externalId     String?   @unique
  lastSyncedAt   DateTime?
  githubRepo     String?   // "owner/repo" when connected to GitHub
  readmeMarkdown String?   // optional synced README content (from GitHub or internal)
  targetVenue    String?   // target conference / journal shown in Overview KPI bar

  // Operational fs path (set by an admin) of the local git checkout for this
  // project. Used by tooling that mirrors files into LabHub. Optional — purely
  // informational projects can leave it null.
  localPath      String?

  repos        ProjectRepo[]
  members      ProjectMember[]
  papers       Paper[]
  releases     Release[]
  runs         ExperimentRun[]
  events       ActivityEvent[]
  entries      ResearchEntry[]
  milestones   Milestone[]
  todos        TodoItem[]
  discussions  Discussion[]
  wikiTypes    WikiType[]
  wikiEntities WikiEntity[]
}

model ProjectMember {
  projectSlug String
  memberLogin String
  project     Project @relation(fields: [projectSlug], references: [slug], onDelete: Cascade)
  member      Member  @relation(fields: [memberLogin], references: [login], onDelete: Cascade)

  @@id([projectSlug, memberLogin])
}

model ProjectRepo {
  id          Int     @id @default(autoincrement())
  projectSlug String
  label       String
  url         String
  project     Project @relation(fields: [projectSlug], references: [slug], onDelete: Cascade)
}

// ========== Papers ==========
model Paper {
  id           String    @id
  title        String
  projectSlug  String
  stage        String
  venue        String?
  deadline     DateTime?
  draftUrl     String?
  pdfUrl       String?
  source       String    @default("internal")
  externalId   String?   @unique
  lastSyncedAt DateTime?

  project Project       @relation(fields: [projectSlug], references: [slug], onDelete: Cascade)
  authors PaperAuthor[]
}

model PaperAuthor {
  paperId     String
  authorLogin String
  position    Int
  paper       Paper  @relation(fields: [paperId], references: [id], onDelete: Cascade)
  author      Member @relation(fields: [authorLogin], references: [login], onDelete: Cascade)

  @@id([paperId, authorLogin])
}

// ========== Experiment Runs ==========
model ExperimentRun {
  id               String    @id
  name             String
  projectSlug      String
  status           String
  startedAt        DateTime
  durationSec      Int?
  triggeredByLogin String
  summary          String?
  stepsJson        String?
  source           String    @default("internal")
  externalId       String?   @unique
  lastSyncedAt     DateTime?

  project     Project @relation(fields: [projectSlug], references: [slug], onDelete: Cascade)
  triggeredBy Member  @relation(fields: [triggeredByLogin], references: [login], onDelete: Restrict)
}

// ========== Discussions ==========
model Discussion {
  id             String    @id
  category       String
  title          String
  authorLogin    String
  projectSlug    String?
  createdAt      DateTime
  lastActivityAt DateTime
  replyCount     Int
  bodyMarkdown   String
  source         String    @default("internal")
  externalId     String?   @unique
  lastSyncedAt   DateTime?

  author  Member   @relation(fields: [authorLogin], references: [login], onDelete: Restrict)
  project Project? @relation(fields: [projectSlug], references: [slug], onDelete: SetNull)
  replies Reply[]
}

model Reply {
  id           String    @id @default(uuid())
  discussionId String
  authorLogin  String
  createdAt    DateTime
  bodyMarkdown String
  position     Int
  source       String    @default("internal")
  externalId   String?   @unique
  lastSyncedAt DateTime?

  discussion Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  author     Member     @relation(fields: [authorLogin], references: [login], onDelete: Restrict)
}

// ========== Releases ==========
model Release {
  id           String    @id
  name         String
  kind         String
  projectSlug  String
  version      String
  publishedAt  DateTime
  description  String?
  downloadUrl  String?
  source       String    @default("internal")
  externalId   String?   @unique
  lastSyncedAt DateTime?

  project Project @relation(fields: [projectSlug], references: [slug], onDelete: Cascade)
}

// ========== Activity events ==========
model ActivityEvent {
  id          String   @id
  type        String
  actorLogin  String
  projectSlug String?
  payload     String
  createdAt   DateTime

  actor   Member   @relation(fields: [actorLogin], references: [login], onDelete: Restrict)
  project Project? @relation(fields: [projectSlug], references: [slug], onDelete: SetNull)
}

// ========== Venues ==========
model Venue {
  id       String   @id
  name     String
  deadline DateTime
  kind     String
}

// ========== Research Journal ==========
model ResearchEntry {
  id            String   @id
  projectSlug   String
  date          DateTime
  type          String   // 'meeting' | 'report' | 'experiment' | 'review'
  authorLogin   String
  title         String
  summary       String
  tags          String   // JSON array
  bodyMarkdown  String
  source        String    @default("internal")
  externalId    String?   @unique
  lastSyncedAt  DateTime?

  project   Project         @relation(fields: [projectSlug], references: [slug], onDelete: Cascade)
  author    Member          @relation(fields: [authorLogin], references: [login], onDelete: Restrict)
  artifacts EntryArtifact[]
  slides    EntrySlide[]
}

model EntryArtifact {
  id       Int    @id @default(autoincrement())
  entryId  String
  type     String // 'notebook' | 'figure' | 'sheet' | 'csv' | 'doc' | 'slide'
  title    String
  href     String
  position Int

  entry ResearchEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
}

model EntrySlide {
  id          Int     @id @default(autoincrement())
  entryId     String
  position    Int     // 0 = summary (implicit), 1+ = narrative
  kind        String  // 'discovery' | 'failure' | 'implement' | 'question' | 'next' | 'metric'
  title       String
  body        String
  chip        String?
  metricsJson String?
  code        String?

  entry ResearchEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
}

model Milestone {
  id          Int      @id @default(autoincrement())
  projectSlug String
  date        DateTime
  label       String
  note        String?
  status      String   // 'past' | 'now' | 'future'
  position    Int

  project Project @relation(fields: [projectSlug], references: [slug], onDelete: Cascade)
}

model TodoItem {
  id          Int      @id @default(autoincrement())
  projectSlug String
  bucket      String   // 'short' | 'mid' | 'long'
  text        String
  done        Boolean  @default(false)
  position    Int

  project Project @relation(fields: [projectSlug], references: [slug], onDelete: Cascade)
}

// ========== Wiki (per-project knowledge entities, LLM-maintained) ==========
//
// Karpathy-style wiki: persistent entity pages (e.g. attacks/defenses/concepts
// for an attack-research project). Each project defines its own type registry
// (WikiType), and entities are namespaced by project + id. Source of truth is
// typically a git folder (Project.localPath/wiki/...) — a sync script mirrors
// files into these tables for indexed access from the UI.

model WikiType {
  id          Int      @id @default(autoincrement())
  projectSlug String
  key         String   // 'attack', 'defense', 'concept', 'finding', 'method', ...
  label       String   // display name e.g. 'Attacks'
  position    Int      @default(0)
  description String?

  project Project @relation(fields: [projectSlug], references: [slug], onDelete: Cascade)
  @@unique([projectSlug, key])
}

model WikiEntity {
  projectSlug     String
  id              String   // slug-style id within the project, e.g. 'trigger_universal'
  type            String   // matches a WikiType.key for the same project
  name            String
  status          String   @default("active") // 'active' | 'deprecated' | 'superseded'
  summaryMarkdown String   @default("")
  bodyMarkdown    String
  sourceFiles     String   @default("[]") // JSON array of relative paths under Project.localPath
  lastSyncedAt    DateTime
  source          String   @default("wiki-llm")

  project Project @relation(fields: [projectSlug], references: [slug], onDelete: Cascade)
  @@id([projectSlug, id])
  @@index([projectSlug, type])
}
